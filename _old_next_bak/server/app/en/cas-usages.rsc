9:["$","$La",null,{"formats":"$undefined","locale":"en","messages":{"Header":{"nav":{"home":"Home","platform":"Platform","solutions":"Solutions","resources":"Resources","company":"Company"},"megaMenu":{"platform":{"title":"Platform","items":{"overview":"Platform overview","modules":"15 integrated modules","governance":"Governance & RBAC","mobile":"Mobile app (PWA)"}},"solutions":{"title":"Solutions","items":{"services":"ITAD services","process":"ITAD process","security":"Security & erasure","impact":"Environmental impact"}},"resources":{"title":"Resources","items":{"demo":"Request a demo","faq":"FAQ","regulation":"Regulations","methodology":"Methodology"}},"company":{"title":"Company","items":{"whyGtc":"Why GreenTechCycle?","journey":"Client journey","ecosystem":"Ecosystem","careers":"Careers"}}},"cta":"Request a demo","languageSwitch":"FR"},"TrustBar":{"text":"R2v3 • ISO 14001 • NIST 800-88 • GDPR & CSRD Compliant"},"Footer":{"tagline":"Your trusted partner for responsible and secure management of end-of-life IT assets. R2, e-Stewards and ISO 14001 certified.","contact":{"title":"Contact us","address":"42 rue de la République\n69002 Lyon, France","phone":"+33 1 86 65 22 10","email":"contact@greentechcycle.fr"},"cta":"Request a quote","columns":{"services":{"title":"Services","links":{"erasure":"Certified erasure","collection":"Secure collection","reporting":"ESG reporting","carbon":"Carbon assessment","blockchain":"Blockchain traceability","wakibox":"WakiBox"}},"company":{"title":"Company","links":{"whyGtc":"Why GTC?","journey":"Client journey","ecosystem":"Ecosystem","careers":"Careers","impact":"Impact","contact":"Contact"}},"resources":{"title":"Resources","links":{"demo":"Request a demo","faq":"FAQ","regulation":"Regulations","methodology":"Methodology","platform":"Platform","security":"Security"}},"legal":{"title":"Legal","links":{"mentions":"Legal notice","privacy":"Privacy policy","terms":"Terms of use","cookies":"Cookie policy"}}},"newsletter":{"title":"Newsletter","placeholder":"Your professional email","cta":"Subscribe"},"copyright":"© 2026 GreenTechCycle. All rights reserved. — SIREN 912 345 678.","bottomLinks":{"legal":"Legal notice","privacy":"Privacy","cookies":"Cookies"}},"CookieBanner":{"title":"Cookie preferences","description":"We use cookies to improve your experience. You can customize your preferences below.","categories":{"necessary":{"title":"Strictly necessary","desc":"Essential for site operation"},"analytics":{"title":"Analytics","desc":"Help us improve our site"},"functional":{"title":"Functional","desc":"Enhanced features (chat, preferences)"},"marketing":{"title":"Marketing","desc":"Advertising tracking and retargeting"}},"acceptAll":"Accept all","rejectAll":"Reject all","customize":"Customize","save":"Save preferences","link":"Cookie policy"},"StickyCTA":{"text":"Request a free audit"},"Home":{"hero":{"title":"Unified ITAD Platform","subtitle":"Certified erasure, blockchain traceability and CSRD reporting in a single tool.","cta1":"Request a demo","cta2":"See the platform"},"urgency":{"text":"CSRD now in effect — Is your ITAD compliant?"},"trust":{"text":"R2v3 • ISO 14001 • NIST 800-88 • GDPR & CSRD Compliant"},"stats":{"title":"The ITAD market in numbers","items":{"stat1":{"value":"78%","label":"of mid-size companies without ITAD traceability"},"stat2":{"value":"50M","label":"tonnes of IT waste per year in Europe"},"stat3":{"value":"€3.2B","label":"European ITAD market in 2025"},"stat4":{"value":"67%","label":"of CIOs want a unified tool"}}},"howItWorks":{"title":"How it works","subtitle":"4 steps to mastering ITAD","steps":[{"title":"Audit","desc":"Complete inventory of your IT assets and risk assessment"},{"title":"Collection","desc":"Secure on-site pickup with full chain of custody"},{"title":"Processing","desc":"NIST certified erasure, refurbishment or recycling"},{"title":"Report","desc":"Certificates, carbon footprint and automated CSRD reporting"}]},"testimonials":{"title":"They trust us","items":[{"quote":"GreenTechCycle has transformed our ITAD management. We finally have complete traceability and automated CSRD reports.","name":"Marie Dupont","role":"CIO","company":"Nexteam Group"},{"quote":"The automatic carbon assessment allowed us to reduce our IT footprint by 40% in one year. Immediate ROI.","name":"Thomas Martin","role":"CSR Manager","company":"Visiativ"},{"quote":"Certified erasure with 24h certificate delivery secured our processes and reassured our auditors.","name":"Sophie Bernard","role":"CFO","company":"Exotrail"}]},"counters":{"title":"GreenTechCycle in numbers","items":{"companies":{"value":"150","suffix":"+","label":"companies supported"},"equipment":{"value":"12000","suffix":"+","label":"devices processed"},"satisfaction":{"value":"98","suffix":"%","label":"satisfaction rate"},"co2":{"value":"45","suffix":"T","label":"CO₂ avoided"}}},"press":{"title":"In the press","outlets":["Les Échos","BFM Business","L'Usine Digitale","GreenBiz","01net","ZDNet"]},"finalCTA":{"title":"Ready to unify your ITAD?","subtitle":"Request a free audit and discover how GreenTechCycle can transform your IT asset management.","cta":"Request a free audit"}},"Services":{"hero":{"title":"Our ITAD Services","subtitle":"6 integrated services for complete end-of-life IT asset management"},"items":[{"id":"erasure","title":"Certified Erasure","subtitle":"NIST 800-88 • DoD 5220.22-M","engagement":"Certificate within 24h","description":"Certified software erasure and physical destruction, compliant with the strictest standards. Each operation generates an individual certificate with verification hash.","features":["3-pass erasure per NIST 800-88","Certified physical destruction (shredding, degaussing)","Individual certificate per asset with SHA-256 hash","Complete erasure chain traceability","Support for all media types (HDD, SSD, tapes)","Consolidated report for auditors"]},{"id":"collection","title":"Secure On-site Collection","subtitle":"Certified logistics","engagement":"Intervention within 48h","description":"Secure collection directly at your premises with uninterrupted chain of custody. GPS-tracked vehicles and authorized personnel.","features":["On-site intervention within 48h across France","Secured vehicles with real-time GPS tracking","Authorized and sworn personnel","Numbered seals and handover report","Anti-shock and anti-static packaging","Full transport insurance"]},{"id":"reporting","title":"ESG & CSRD Reporting","subtitle":"ESRS E5 Compliant","engagement":"Automatic export","description":"Automatic generation of reports compliant with CSRD/ESRS requirements. Data ready for integration into your extra-financial report.","features":["ESRS E5 compliant reports (circular economy)","PDF, Word and Excel export by role","Scope 1, 2 and 3 carbon data","Pre-calculated CSRD indicators","Year-over-year history and comparison","Export API for your reporting tools"]},{"id":"carbon","title":"IT Carbon Assessment","subtitle":"Boavizta • ADEME methodology","engagement":"Automatic calculation","description":"Automatic calculation of your end-of-life IT fleet carbon footprint. Certified methodology based on Boavizta and ADEME frameworks.","features":["Automatic calculation via Boavizta API","GHG Protocol scopes 1, 2 and 3","Emissions avoided through reuse","Updated ADEME emission factors","Real-time carbon metrics dashboard","Export for regulatory GHG report"]},{"id":"blockchain","title":"Blockchain Traceability","subtitle":"Certified chain of custody","engagement":"Immutable proof","description":"Every step of your assets' lifecycle is recorded on blockchain, ensuring tamper-proof and third-party verifiable traceability.","features":["Immutable recording of each step","End-to-end chain of custody","QR code verification for auditors","eIDAS certified timestamping","GDPR compliance proof","Real-time tracking dashboard"]},{"id":"wakibox","title":"WakiBox","subtitle":"Smart IoT collection kiosks","engagement":"Real-time monitoring","description":"Connected collection kiosks installed at your premises. Automatic deposit detection, integrated weighing and fill-level alerts.","features":["Plug-and-play connected collection kiosk","Automatic RFID deposit detection","Integrated weighing and automatic classification","Real-time fill-level alerts","Per-site tracking dashboard","Gamification to encourage reuse"]}]},"Process":{"hero":{"title":"ITAD Process","subtitle":"A 7-step workflow for end-to-end managed IT asset disposition"},"steps":[{"number":"01","title":"Fleet Audit","description":"Comprehensive inventory of your IT assets: type, age, condition, sensitive data. Risk assessment and personalized recommendations."},{"number":"02","title":"Secure Collection","description":"On-site pickup with authorized personnel. Numbered seals, handover report and GPS-tracked transport."},{"number":"03","title":"Secure Transport","description":"Dedicated vehicles with real-time geolocation. Anti-shock packaging and full risk insurance."},{"number":"04","title":"Certified Erasure","description":"NIST 800-88 software erasure or physical destruction. Individual certificate per asset with verification hash."},{"number":"05","title":"Refurbishment","description":"Complete diagnostic, upgrade and compliance testing. Eligible equipment is prepared for a second life."},{"number":"06","title":"Value Recovery","description":"Resale on the refurbished market, charitable donation or certified recycling. Maximizing residual value."},{"number":"07","title":"Certificate & Reporting","description":"Erasure certificates, waste tracking slips, carbon assessment and CSRD report. Everything documented and auditable."}]},"Platform":{"hero":{"eyebrow":"Unified ITAD platform","title":"One platform for your entire ITAD lifecycle","subtitle":"Inventory, erase, trace, recover value and report from a single source of truth. From pickup to CSRD certificate — no rekeying, no silos, no blind spots.","ctaPrimary":"Request a demo","ctaSecondary":"See the platform in action","badges":["ISO 27001","NIST 800-88","GDPR · NIS2 · DORA","R2v3 · ISO 14001"]},"unified":{"eyebrow":"The concept","title":"No more silos. One connected platform.","subtitle":"Most ITAD teams juggle 4 to 6 tools: ITAM, carbon spreadsheets, erasure software, compliance docs. GreenTechCycle replaces them with a single platform where every module feeds the next in real time.","before":{"title":"Before · Fragmented tools","items":["ITAM & CMDB for inventory","Separate erasure software","Excel spreadsheet for carbon","Word documents for compliance","Email & phone for logistics","Manual PDFs for reporting"]},"after":{"title":"With GreenTechCycle · Unified platform","items":["Unified, always-updated inventory & audit","NIST / DoD certified erasure built-in","Automated Scope 1/2/3 carbon assessment","GDPR, NIS2, DORA, CSRD compliance in continuous","Traced logistics and chain of custody","Multi-role reporting, exported in 1 click"]},"kpis":[{"value":"-65%","label":"admin time"},{"value":"100%","label":"asset-level traceability"},{"value":"1","label":"single source of truth"}]},"workflow":{"eyebrow":"End-to-end journey","title":"Your ITAD lifecycle, orchestrated in 6 connected steps","subtitle":"Every module triggers the next. Data flows automatically, responsibilities are tracked, exports are ready for your auditors.","steps":[{"number":"01","title":"Inventory & Audit","description":"Automatic fleet discovery, CMDB/ITAM import, field audit via QR scan. Every asset is photographed, timestamped and linked to its business owner.","highlights":["CSV / API import","QR scan & photos","Guided physical audit"]},{"number":"02","title":"Scoring & Assessment","description":"Automatic scoring of residual value, cyber risk and carbon footprint. The platform computes a decision score for every asset.","highlights":["Residual value","Vulnerability score","Estimated CO₂ impact"]},{"number":"03","title":"ITAD Decision","description":"Refurbish, resell, recycle or destroy: the platform recommends the best channel for every asset based on your policies and ESG goals.","highlights":["Refurbish","Resell / donate","Recycle or destroy"]},{"number":"04","title":"Traceability & Compliance","description":"Timestamped chain of custody, NIST 800-88 certified erasure, digital seals and destruction proofs. Every action is logged.","highlights":["Chain of custody","Certified erasure","Signed proofs"]},{"number":"05","title":"Reporting","description":"Role-specific reports: CIO, CISO, CFO, ESG. CSRD, Scope 1/2/3 carbon, R2v3 certificates, all exportable in 1 click.","highlights":["CIO · CISO · ESG","CSRD & Scope 3","1-click export"]},{"number":"06","title":"Continuous Monitoring","description":"Real-time dashboard, drift alerts, KPI tracking and continuous improvement. ITAD becomes pilotable, not just documented.","highlights":["Real-time KPIs","Alerts & SLAs","Continuous improvement"]}]},"security":{"eyebrow":"Governance & Security","title":"Designed for CISOs and auditors","subtitle":"Automated cyber risk audit, military-grade certified erasure, multi-framework compliance: everything is built-in, nothing needs to be rekeyed.","pillars":[{"title":"Cyber risk audit","description":"Per-asset vulnerability scoring, detection of data exposure risks and prioritization of ITAD flows based on criticality.","features":["Vulnerability score per device","Residual sensitive data detection","Automatic prioritization of critical flows","SIEM and GRC tool integration"]},{"title":"Certified erasure","description":"Cryptographic and logical erasure compliant with NIST 800-88 Rev.1, DoD 5220.22-M and IEEE 2883. Signed certificate generated for every drive.","features":["NIST 800-88 Rev.1 (Clear / Purge / Destroy)","DoD 5220.22-M (3 passes)","IEEE 2883 for SSD/NVMe","Signed certificate with hash and timestamp"]},{"title":"Regulatory compliance","description":"GDPR, NIS2, DORA, ISO 27001: the platform maintains a live compliance matrix and generates the evidence your auditors expect.","features":["GDPR · record keeping and DPIA","NIS2 · risk management measures","DORA · IT operational resilience","ISO 27001 · ISMS and A controls"]},{"title":"ESG & Sustainability audit","description":"ISO 14001, Scope 1/2/3 carbon assessment, destruction certificates and circular economy indicators, ready for your CSRD reporting.","features":["ISO 14001 · documented EMS","Scope 1/2/3 · ADEME factors","Reuse and recovery rates","R2v3 and WEEE certificates"]}],"certifications":["ISO 27001","NIST 800-88","DoD 5220.22-M","IEEE 2883","ISO 14001","R2v3","GDPR","NIS2","DORA"],"timeline":{"title":"From pickup to certificate, fully auditable","steps":["Sealed pickup · GPS proof","Reception · weigh-in and photo","NIST erasure · signed hash","Certificate · signature + timestamp","Auditor dossier filed"]}},"recycling":{"eyebrow":"Recycling & Value Recovery","title":"Turn IT end-of-life into measurable value","subtitle":"The platform routes every asset to the channel that maximizes value — for your budget and for the planet. Circular economy, concretely.","flow":[{"title":"Assess","description":"Analyze market residual value, functional condition and reuse potential for every asset."},{"title":"Refurbish","description":"Functional testing, cosmetic restoration, system reinstallation and compliance checks before resale."},{"title":"Resell or donate","description":"Internal marketplace, B2B resale, donations to charities or reintroduction to internal fleet at lower cost."},{"title":"Responsible recycling","description":"Accredited WEEE channel for non-reusable assets: dismantling, sorting and raw material traceability."}],"kpis":[{"value":"72%","label":"Average reuse rate observed"},{"value":"€380","label":"Average value recovered per workstation"},{"value":"45T","label":"CO₂ avoided in 2025 (GTC clients)"},{"value":"100%","label":"Accredited and traced WEEE channels"}],"cta":"Estimate my fleet's recovery potential"},"reporting":{"eyebrow":"Multi-role reporting","title":"One report for each stakeholder, in one click","subtitle":"No more manual consolidation. The platform aggregates data and generates the report each team expects, with the right level of detail and the right format.","useCases":[{"role":"For the CIO","title":"Fleet status & cost avoidance","description":"Live inventory, end-of-life assets, refurbishment budget vs new purchase, residual value captured.","metrics":["Costs avoided","End-of-life fleet","Refurb ROI"]},{"role":"For the CISO","title":"Risk audit & erasure proofs","description":"Per-asset risk score, NIST/DoD certificates, audit log, NIS2 and DORA matrix ready for the auditor.","metrics":["At-risk assets","Certificates generated","NIS2 compliance"]},{"role":"For ESG / Sustainability","title":"Carbon footprint & CSRD","description":"Scope 1/2/3 computed from actual flows, recovery rate, CSRD ESRS E5 reporting and ISO 14001 indicators.","metrics":["Scope 3 avoided","Reuse rate","CSRD ESRS E5"]},{"role":"For the CFO","title":"Finance & asset value recovery","description":"Resale revenue, credits generated, remaining depreciation, disposal provision and P&L impact.","metrics":["Resale revenue","Credits","P&L impact"]}],"formats":["Executive PDF","Word for auditors","Excel data","JSON API"],"dashboardTitle":"Reporting dashboard","dashboardSubtitle":"A single workspace, tailored by role","exportLabel":"Export in 1 click"},"mobile":{"eyebrow":"Mobile application","title":"Your field teams, connected in real time","subtitle":"The GreenTechCycle mobile app puts the platform in your technicians' pockets. Scan, input, photos, signatures: everything flows back instantly, even offline.","features":[{"title":"QR & barcode scan","description":"Identify an asset in 2 seconds, access its full history and update its status from the field."},{"title":"Guided interventions","description":"Dynamic checklists, mandatory photos, digital signatures: every intervention is tracked and compliant."},{"title":"Push notifications","description":"New pickups, pending approvals, SLA alerts: your technicians never miss what matters."},{"title":"Offline mode","description":"Warehouses without network, sensitive areas: the app works offline and syncs as soon as connection is back."}],"tagline":"Already used by 800+ field technicians","storeApple":"Download on the App Store","storeGoogle":"Get it on Google Play"},"cta":{"title":"Ready to unify your ITAD?","subtitle":"Talk to a GreenTechCycle expert — personalized demo, fleet assessment and deployment plan in 20 minutes.","primary":"Request a demo","secondary":"Talk to an expert"}},"WhyGTC":{"hero":{"title":"Why GreenTechCycle?","subtitle":"Move from 4 fragmented tools to 1 unified platform"},"before":{"title":"Before: 4 fragmented tools","items":["ITAM (asset management)","Separate erasure tool","Manual carbon spreadsheet","Compliance on Word documents"]},"after":{"title":"After: 1 GTC platform","items":["Inventory + erasure + carbon + compliance","End-to-end blockchain traceability","Automated CSRD reporting","One dashboard for all roles"]},"benefits":{"title":"Concrete benefits","items":[{"title":"Time savings","desc":"60% reduction in ITAD administrative time"},{"title":"Guaranteed compliance","desc":"100% CSRD, GDPR, NIS2 and DORA compliant"},{"title":"Total visibility","desc":"Traceability of every asset from audit to certificate"},{"title":"Measurable ROI","desc":"Asset recovery and 40% cost reduction"}]}},"ClientJourney":{"hero":{"title":"Client Journey","subtitle":"From initial audit to continuous reporting, we support you at every step"},"steps":[{"number":"1","title":"Free Audit","description":"Complete diagnostic of your IT fleet and current ITAD processes. Risk identification and optimization opportunities.","duration":"1 to 2 weeks"},{"number":"2","title":"Tailored Proposal","description":"Customized action plan with detailed pricing, deployment timeline and ROI estimate.","duration":"48h after audit"},{"number":"3","title":"Platform Deployment","description":"Platform configuration, integration with your existing tools (ServiceNow, GLPI, etc.) and team training.","duration":"2 to 4 weeks"},{"number":"4","title":"Field Operations","description":"Secure collections, certified erasure and refurbishment. Real-time tracking from the platform.","duration":"Ongoing"},{"number":"5","title":"Continuous Reporting","description":"Automated CSRD reports, updated carbon assessment and certificates available in real-time on the platform.","duration":"Ongoing"}]},"Ecosystem":{"hero":{"title":"Ecosystem & Integrations","subtitle":"GreenTechCycle integrates natively with your existing tools"},"integrations":{"title":"Native Integrations","items":[{"name":"ServiceNow","desc":"Bi-directional synchronization of IT assets and ITAD tickets"},{"name":"GLPI","desc":"Automatic inventory import and status updates"},{"name":"Microsoft Intune","desc":"Detection of assets to decommission and remote wipe"},{"name":"JAMF","desc":"Apple device lifecycle management"},{"name":"SAP","desc":"Accounting integration and fixed asset tracking"}]},"api":{"title":"Open API","subtitle":"Documented REST API for custom integrations","features":["REST API v2 with OpenAPI documentation","Webhooks for real-time events","Python and JavaScript SDKs available","Rate limiting and OAuth2 authentication","Test sandbox available"]},"sso":{"title":"Authentication","subtitle":"Enterprise SSO and identity management","features":["SAML 2.0 (Azure AD, Okta, OneLogin)","OIDC (Google Workspace, Keycloak)","SCIM for automatic provisioning","Mandatory MFA for sensitive operations"]}},"Regulation":{"hero":{"title":"Regulations","subtitle":"Understanding the obligations that impact your ITAD"},"timeline":[{"name":"CSRD","date":"In effect","status":"active","description":"Corporate Sustainability Reporting Directive — Mandatory extra-financial reporting including electronic waste management and circular economy.","itadImpact":"Mandatory traceability of end-of-life IT assets, scope 3 emissions reporting for hardware.","sanctions":"Financial penalties and executive liability for non-compliance."},{"name":"NIS2","date":"2024","status":"active","description":"Network and Information Security Directive — Extended scope to mid-size companies with strengthened security obligations.","itadImpact":"Mandatory certified erasure for essential and important entities. Data-related incident notification.","sanctions":"Up to €10M or 2% of global turnover for essential entities."},{"name":"DORA","date":"2025","status":"upcoming","description":"Digital Operational Resilience Act — Digital operational resilience for the financial sector.","itadImpact":"Risk management for ITAD providers. Regular audits and tests of destruction processes.","sanctions":"Administrative sanctions up to 1% of average daily turnover."},{"name":"AI Act","date":"2026","status":"upcoming","description":"European AI Regulation — Framework for AI systems based on risk levels.","itadImpact":"Lifecycle management of AI systems embedded in IT hardware. Training data traceability.","sanctions":"Up to €35M or 7% of global turnover for the most serious violations."}]},"Methodology":{"hero":{"title":"Methodology","subtitle":"Our frameworks and methods for ITAD excellence"},"carbon":{"title":"Carbon Methodology","subtitle":"Certified environmental impact calculation","description":"Our carbon footprint calculation is based on Boavizta and ADEME frameworks, covering GHG Protocol scopes 1, 2 and 3.","items":["Boavizta API for IT equipment emission factors","ADEME carbon database for transport and energy emission factors","Scope 1: direct emissions (collection transport)","Scope 2: indirect emissions (processing center energy)","Scope 3: avoided emissions (reuse vs new manufacturing)","Methodology audited annually by independent third party"]},"erasure":{"title":"Erasure Methodology","subtitle":"NIST 800-88 rev. 1 compliance","levels":[{"name":"Clear","desc":"Single overwrite — for non-sensitive data"},{"name":"Purge","desc":"Multi-pass overwrite — for confidential data"},{"name":"Destroy","desc":"Physical destruction — for classified data"}],"description":"Each erasure level is applied according to data sensitivity classification, in compliance with NIST 800-88 revision 1 recommendations."},"valuation":{"title":"Valuation Methodology","subtitle":"Transparent grading scale","criteria":["Cosmetic condition (A/B/C/D)","Technical performance (benchmarks)","Software compatibility (supported OS)","Battery life (for laptops)","Model age","Refurbished market demand"],"description":"Each asset is evaluated using an objective and transparent grading scale, maximizing residual value."}},"Demo":{"hero":{"title":"Request a Demo","subtitle":"See the GreenTechCycle platform in action"},"video":{"title":"Presentation Video","placeholder":"Video coming soon"},"screenshots":{"title":"Platform Preview","items":["Main dashboard","Erasure module","CSRD reporting","Blockchain traceability","Carbon assessment"]},"form":{"title":"Schedule Your Demo","subtitle":"Fill out the form and our team will contact you within 24h","fields":{"name":"Full name","company":"Company","email":"Professional email","phone":"Phone","equipment":"Number of IT devices","message":"Message (optional)"},"equipmentOptions":["Less than 100","100 to 500","500 to 2,000","2,000 to 10,000","More than 10,000"],"submit":"Request my demo","success":"Thank you! Our team will contact you within 24h."}},"Security":{"hero":{"title":"Security","subtitle":"An end-to-end security approach to protect your data"},"levels":{"title":"5 Erasure Levels","items":[{"level":"1","name":"Standard Deletion","desc":"File deletion and quick format. Suitable for non-sensitive internal data.","norm":"No specific standard"},{"level":"2","name":"Single Overwrite","desc":"One overwrite pass with verification. For low-sensitivity data.","norm":"NIST 800-88 Clear"},{"level":"3","name":"Multi-pass Overwrite","desc":"3 overwrite passes with alternating patterns and complete verification.","norm":"NIST 800-88 Purge / DoD 5220.22-M"},{"level":"4","name":"Cryptographic Erasure","desc":"Encryption key destruction rendering data irrecoverable. Ideal for SSDs.","norm":"NIST 800-88 Purge (crypto)"},{"level":"5","name":"Physical Destruction","desc":"Shredding, degaussing or certified incineration. For defense-classified data.","norm":"NIST 800-88 Destroy"}]},"chainOfCustody":{"title":"Chain of Custody","subtitle":"Uninterrupted traceability from collection to certificate","steps":["Handover with signed report","Numbered seal applied","GPS-tracked transport","Receipt and seal verification","Processing under video surveillance","Erasure certificate issued","Blockchain recording"]},"certifications":{"title":"Our Certifications","items":["R2v3 (Responsible Recycling)","ISO 14001 (Environmental Management)","ISO 27001 (Information Security)","e-Stewards","Qualiopi (Training)"]},"architecture":{"title":"GTC Security Architecture","items":["EU hosting (France) — OVHcloud SecNumCloud","AES-256 encryption at rest and TLS 1.3 in transit","WAF and DDoS protection","Encrypted multi-site backups","Annual penetration testing by independent firm","SOC 2 Type II certification in progress"]}},"Impact":{"hero":{"title":"Environmental Impact","subtitle":"Measure and reduce your IT fleet's carbon footprint"},"metrics":{"title":"Key Metrics","items":[{"value":"45T","label":"CO₂ avoided in 2025"},{"value":"72%","label":"reuse rate"},{"value":"98%","label":"recovery rate"},{"value":"0%","label":"landfill disposal"}]},"calculator":{"title":"Impact Calculator","subtitle":"Estimate the environmental impact of your IT decommissioning","equipmentLabel":"Number of devices","equipmentPlaceholder":"E.g.: 500","results":{"co2":"Tonnes CO₂ avoided","reuse":"Estimated reuse rate","value":"Estimated residual value"},"calculate":"Calculate my impact","note":"Estimate based on our average data. Contact us for a personalized calculation."},"csrd":{"title":"CSRD Reporting","subtitle":"Data ready for your extra-financial report","features":["Pre-calculated ESRS E5 indicators","Minimum 3-year history","Multi-format export (PDF, Excel, API)","Comparison with industry benchmarks","Validation by our ESG team"]}},"Contact":{"hero":{"title":"Contact Us","subtitle":"Our team responds within 24h"},"form":{"name":"Full name","email":"Professional email","company":"Company","phone":"Phone","type":"Subject","typeOptions":{"quote":"Quote request","info":"Information request","partnership":"Partnership","other":"Other"},"message":"Your message","submit":"Send message","success":"Message sent! We'll respond within 24h."},"info":{"address":"42 rue de la République\n69002 Lyon, France","phone":"+33 1 86 65 22 10","email":"contact@greentechcycle.fr"},"crisp":{"placeholder":"Live chat — Crisp configuration required"}},"FAQ":{"hero":{"title":"Frequently Asked Questions","subtitle":"Answers to the most common questions, organized by role"},"tabs":{"dsi":"CIO / CISO","rse":"CSR","daf":"CFO","compliance":"Compliance"},"dsi":[{"q":"What erasure standards do you use?","a":"We apply NIST 800-88 rev.1 (Clear, Purge, Destroy) and DoD 5220.22-M standards. Each operation generates an individual certificate with SHA-256 hash."},{"q":"How do you guarantee chain of custody?","a":"Every asset is tracked end-to-end: handover report, numbered seals, GPS transport, video-monitored processing and blockchain recording."},{"q":"Is the platform compatible with our ITSM?","a":"Yes, we offer native integrations with ServiceNow, GLPI, Intune and JAMF. Our REST API also enables custom integrations."},{"q":"Where is our data hosted?","a":"All data is hosted in France at OVHcloud (SecNumCloud qualification). AES-256 encryption at rest and TLS 1.3 in transit."},{"q":"What is the platform SLA?","a":"We guarantee 99.9% uptime SLA with 24/7 priority support for critical incidents."},{"q":"How do you handle equipment under manufacturer warranty?","a":"We systematically check warranty status and propose manufacturer return when relevant, before any ITAD processing."},{"q":"Can you operate across multiple sites?","a":"Yes, we operate across all of France and in 12 European countries. The platform natively supports multi-site management."},{"q":"How does the platform RBAC work?","a":"5 predefined roles (Admin, Manager, Operator, Auditor, Reader) with 4-eyes principle for sensitive operations. Customization available."}],"rse":[{"q":"How do you calculate the carbon footprint?","a":"Via Boavizta API and ADEME emission factors. We cover scopes 1 (transport), 2 (energy) and 3 (emissions avoided through reuse)."},{"q":"Is the data CSRD compatible?","a":"Yes, our reports comply with ESRS standards, particularly E5 (circular economy). Automatic export in required formats."},{"q":"What is the average reuse rate?","a":"On average, 72% of collected equipment is refurbished and reused. The remainder is recycled through certified channels."},{"q":"Do you offer charitable donations?","a":"Yes, we work with a network of partner charities. Refurbished equipment can be directed to donations with tax receipts."},{"q":"How do you measure avoided emissions?","a":"By comparing the carbon impact of reuse vs manufacturing new equipment, using certified Boavizta methodology."},{"q":"Do you provide an annual impact report?","a":"Yes, each client receives a detailed annual impact report with carbon metrics, reuse rates, and SDG contributions."}],"daf":[{"q":"What is the pricing model?","a":"Per-asset pricing with volume discounts. No setup fees or hidden subscriptions. Custom quote within 48h."},{"q":"Is there a buyback value for equipment?","a":"Yes, refurbishable equipment generates a buyback value deducted from the invoice. Average 15-30% of residual value."},{"q":"How do you handle billing?","a":"Detailed monthly billing by site and operation type. Accounting export compatible with SAP, Sage and Cegid."},{"q":"What is the average ROI?","a":"Our clients see an average 200% ROI over 12 months through asset recovery and operational cost reduction."},{"q":"Do you offer contractual commitments?","a":"Flexible 12 to 36-month contracts with exit clause. Option to start with a 3-month no-commitment pilot."}],"compliance":[{"q":"Are you GDPR compliant?","a":"Yes, as a data processor under GDPR. DPA available, up-to-date processing register, designated DPO and supporting certifications."},{"q":"How do you prove data destruction?","a":"Individual erasure certificate per asset with SHA-256 hash, eIDAS timestamping and blockchain recording for irrefutable proof."},{"q":"Are you auditable?","a":"Yes, we facilitate audits: read-only platform access for auditors, pre-formatted reports and dedicated support."},{"q":"What about NIS2 compliance?","a":"Our certified erasure process meets NIS2 requirements for essential and important entities. Compliance documentation available."},{"q":"How do you handle data transfers outside the EU?","a":"No transfers outside the EU. French hosting, exclusively European subcontractors, GDPR compliance contractually guaranteed."}]},"Careers":{"hero":{"title":"Join Us","subtitle":"Be part of the sustainable ITAD revolution"},"mission":{"title":"Our Mission","description":"At GreenTechCycle, we believe responsible IT asset management is possible without compromising on security or performance. We're building the platform that makes ITAD simple, traceable and virtuous."},"values":{"title":"Our Values","items":[{"title":"Impact","desc":"Every line of code, every field operation has a measurable environmental impact."},{"title":"Transparency","desc":"Total traceability, open data, honest communication with our clients and among ourselves."},{"title":"Excellence","desc":"Certifications, standards, audits: we aim for operational excellence every day."},{"title":"Innovation","desc":"Blockchain, IoT, AI: we push the boundaries of what ITAD can be."}]},"spontaneous":{"title":"Spontaneous Application","description":"No opening matches your profile? Send us your spontaneous application.","cta":"Send my application","email":"recruitment@greentechcycle.fr"}},"Legal":{"mentions":{"title":"Legal Notice","content":{"editor":{"title":"Website Publisher","text":"GreenTechCycle SAS with capital of €50,000\nSIREN: 912 345 678\nRCS Lyon B 912 345 678\nRegistered office: 42 rue de la République, 69002 Lyon, France\nPublication director: Jean-Marc Duval, President\nPhone: +33 1 86 65 22 10\nEmail: contact@greentechcycle.fr"},"hosting":{"title":"Hosting","text":"OVHcloud SAS\n2 rue Kellermann, 59100 Roubaix, France\nSIREN: 424 761 419\nPhone: 1007\nWebsite: www.ovhcloud.com"},"ip":{"title":"Intellectual Property","text":"All content on this website (text, images, videos, logos, trademarks) is protected by intellectual property law. Any reproduction, representation or distribution, in whole or in part, without prior written authorization from GreenTechCycle is prohibited."},"liability":{"title":"Liability","text":"GreenTechCycle strives to ensure the accuracy of information published on this website but cannot be held responsible for errors, omissions or results obtained from the use of this information."}}},"cgu":{"title":"Terms of Use","content":{"object":{"title":"Article 1 — Purpose","text":"These Terms of Use define the conditions for accessing and using the greentechcycle.fr website and the GreenTechCycle platform."},"access":{"title":"Article 2 — Website Access","text":"The website is freely accessible to any user with internet access. Access to the GreenTechCycle platform requires creating a user account subject to validation."},"account":{"title":"Article 3 — User Account","text":"Users agree to provide accurate information when creating their account. They are responsible for the confidentiality of their credentials and all activity performed from their account."},"usage":{"title":"Article 4 — Service Usage","text":"Users agree to use the platform in accordance with its intended purpose and applicable laws. Any abusive, fraudulent or inappropriate use may result in account suspension."},"ip":{"title":"Article 5 — Intellectual Property","text":"All platform elements (code, design, content, trademarks) are the exclusive property of GreenTechCycle. Users have a limited right of use within the scope of their contract."},"liability":{"title":"Article 6 — Liability","text":"GreenTechCycle implements all reasonable means to ensure platform availability and security. GreenTechCycle's liability is limited to direct and foreseeable damages."},"termination":{"title":"Article 7 — Termination","text":"GreenTechCycle reserves the right to suspend or terminate platform access in case of Terms violation, after prior notification except in emergencies."},"law":{"title":"Article 8 — Applicable Law","text":"These Terms are governed by French law. Any dispute shall be submitted to the exclusive jurisdiction of the courts of Lyon."}}},"privacy":{"title":"Privacy Policy","content":{"intro":{"title":"Introduction","text":"GreenTechCycle SAS ('GreenTechCycle') is committed to protecting the privacy of users of its website and platform. This policy describes the personal data collected and how it is processed."},"controller":{"title":"Data Controller","text":"GreenTechCycle SAS\n42 rue de la République, 69002 Lyon\nDPO: dpo@greentechcycle.fr"},"data":{"title":"Data Collected","text":"We collect the following data:\n• Identification data: name, surname, email, phone\n• Professional data: company, position, sector\n• Connection data: IP address, access logs, cookies\n• Usage data: platform actions, preferences"},"purpose":{"title":"Processing Purposes","text":"Your data is processed for:\n• Providing and improving our services\n• Client relationship management\n• Sending commercial communications (with consent)\n• Compliance with legal obligations\n• Platform security"},"legal":{"title":"Legal Basis","text":"Data processing is based on:\n• Contract performance (service delivery)\n• Consent (cookies, newsletter)\n• Legitimate interest (security, service improvement)\n• Legal obligation (accounting records)"},"retention":{"title":"Retention Period","text":"• Active client data: contract duration + 3 years\n• Prospects: 3 years after last contact\n• Connection data: 12 months\n• Accounting data: 10 years"},"rights":{"title":"Your Rights","text":"Under GDPR, you have the following rights:\n• Right of access to your data\n• Right to rectification\n• Right to erasure\n• Right to data portability\n• Right to object\n• Right to restriction of processing\n\nTo exercise your rights: dpo@greentechcycle.fr"},"cookies":{"title":"Cookies","text":"Please refer to our dedicated cookie policy for more information on cookie usage."},"transfers":{"title":"Data Transfers","text":"No data is transferred outside the European Union. All our subcontractors are located within the EU and subject to strict contractual clauses."},"update":{"title":"Updates","text":"This policy may be updated. The date of last update is indicated at the top of the page. Last update: April 2026."}}},"cookies":{"title":"Cookie Policy","content":{"intro":{"title":"What is a cookie?","text":"A cookie is a small text file placed on your device when visiting a website. It allows the site to remember information about your visit."},"categories":{"title":"Cookie Categories","necessary":{"title":"Strictly Necessary Cookies","text":"Essential for site operation. Cannot be disabled. Examples: session, language preferences, security."},"analytics":{"title":"Analytics Cookies","text":"Allow us to measure site traffic and improve its performance. Tool used: Matomo (hosted in France)."},"functional":{"title":"Functional Cookies","text":"Enhance your experience (live chat Crisp, display preferences). Can be disabled without affecting basic functionality."},"marketing":{"title":"Marketing Cookies","text":"Used for advertising tracking and retargeting. Only placed with your explicit consent."}},"management":{"title":"Managing Your Preferences","text":"You can change your preferences at any time by clicking the 'Cookie settings' link at the bottom of the page or through your browser settings."},"duration":{"title":"Retention Period","text":"Cookies are stored for a maximum of 13 months in accordance with CNIL recommendations."}}}},"NotFound":{"title":"Page Not Found","subtitle":"The page you are looking for does not exist or has been moved.","cta":"Back to home","links":{"services":"Our services","contact":"Contact us","demo":"Request a demo"}},"ExitPopup":{"title":"Get our free guide","subtitle":"The complete guide to CSRD-compliant ITAD — 40 pages of best practices.","placeholder":"Your professional email","cta":"Get the guide","dismiss":"No thanks"},"UseCases":{"hero":{"title":"Use Cases","subtitle":"Real-world scenarios showing how GreenTechCycle transforms your ITAD"},"cases":[{"id":"migration-windows","tag":"Migration","title":"Windows migration: 500 workstations in a warehouse","scenario":"A mid-size company migrates from Windows 10 to 11. 500 laptops stacked in a server room. The auditor asks for erasure certificates. The DPO demands proof of client data deletion. Finance wants to recover residual value. CSR needs the carbon footprint for CSRD reporting.","stakeholders":"CIO, CISO/DPO, CFO, CSR, Facilities","solution":"A single workflow — intervention created from the IT Fleet module, collection orchestrated, NIST 800-88 erasure device by device, certificates auto-generated, carbon footprint calculated via Boavizta API, residual value assessed by Asset Intelligence. Each stakeholder accesses their dedicated dashboard."},{"id":"data-breach","tag":"Security","title":"The post-data breach nightmare","scenario":"A former executive's laptop resurfaces on a second-hand market with strategic data. GDPR notification required within 72 hours. The insurer demands proof of a formal erasure process. It doesn't exist.","stakeholders":"DPO, CISO, Legal, CEO","solution":"End-to-end chain of custody tracked in GTC. eIDAS-signed certificates with SHA-256 hash. Verifiable proof in 3 clicks for any device, even those processed 3 years ago. Blockchain recording makes the proof irrefutable."},{"id":"csrd-report","tag":"CSRD","title":"The CSRD report: 3 weeks of pain","scenario":"The CSR manager must document IT scope 3 for the CSRD report. They contact 4 ITAD providers, each sends an Excel in a different format. 3 weeks of manual consolidation. Approximate results. The external auditor is unsatisfied.","stakeholders":"CSR, Management control, CIO, External auditor","solution":"Automatic carbon footprint via Boavizta API, CSRD-compliant ESRS E5 export in 15 minutes. Auditable data, documented methodology, 3-year history. The auditor validates in a single session."},{"id":"multi-sites","tag":"Multi-site","title":"Multi-site: 15 branches, 15 different approaches","scenario":"A retail group with 15 branches across France. Each manager handles end-of-life IT their own way — some discard, some store, some donate without tracking. Zero group visibility. An audit reveals 8 GDPR non-compliance issues.","stakeholders":"Group CIO, 15 branch managers, Compliance, Procurement, Logistics","solution":"One process, one platform. Each site has its own space, the group gets real-time visibility. Centralized certificates, per-site compliance verification. Group compliance audit done from the dashboard in a few clicks."},{"id":"cfo-value","tag":"Value Recovery","title":"The CFO who discovers they're throwing away money","scenario":"€800K in annual IT depreciation, systematic destruction of all equipment. In reality, 40% could have been refurbished and resold. 3-year-old Dell PowerEdge servers, Cisco switches — still plenty of value on the refurbished market.","stakeholders":"CFO, CIO, Procurement, Accounting","solution":"The Asset Intelligence module automatically evaluates residual value from manufacturer references and equipment condition. Clear recommendation: destroy / refurbish / resell. The CFO sees recoverable value before any decision."},{"id":"nis2","tag":"NIS2","title":"NIS2 compliance under pressure","scenario":"NIS2 is in effect. The CISO must prove to the board that IT decommissioning is under control. They have a spreadsheet and paper certificates in a drawer. The national cybersecurity agency can audit at any time.","stakeholders":"CISO, CIO, Compliance, Board","solution":"The GTC platform IS the proof. Real-time inventory, step-by-step decommissioning tracking, digitally signed certificates, compliance matrix covering 22 standards and regulations. Regulatory audit prepared in 10 minutes."},{"id":"wakibox-campus","tag":"WakiBox","title":"WakiBox deployment on a corporate campus","scenario":"A corporate campus with 3,000 employees wants to simplify obsolete IT equipment collection. Devices linger in drawers or end up in the trash. No traceability.","stakeholders":"CIO, Facilities, CSR, Employees","solution":"Deployment of 10 WakiBox IoT kiosks at strategic campus locations. Smart collection with RFID detection, real-time fill-level monitoring, automatic IT waste classification. Gamification to encourage deposits. CSR tracks carbon impact in real time."}],"unified":{"title":"Why an all-in-one platform?","subtitle":"Compare: 4 fragmented tools vs 1 unified platform","comparison":{"headers":{"criteria":"Criteria","fragmented":"4 separate tools","gtc":"GreenTechCycle"},"rows":[{"criteria":"Dashboards","fragmented":"4 different dashboards","gtc":"1 unified dashboard"},{"criteria":"Authentication","fragmented":"4 logins, 4 passwords","gtc":"1 single SSO"},{"criteria":"Reporting","fragmented":"4 incompatible formats","gtc":"1 multi-format export"},{"criteria":"Data","fragmented":"No interconnection","gtc":"End-to-end integrated flow"},{"criteria":"Total cost","fragmented":"Snipe-IT + Blancco + Greenly + Vanta","gtc":"1 license, all included"},{"criteria":"Admin time","fragmented":"Triple entry, manual consolidation","gtc":"Single entry, automation"}]}},"cta":{"title":"Do you recognize your situation?","subtitle":"Request a free audit and discover how GreenTechCycle can solve your challenge.","button":"Request a free audit"}},"Sectors":{"finance":{"hero":{"title":"ITAD for Financial Services","subtitle":"DORA, PCI-DSS, regulatory oversight — secure your critical IT asset decommissioning"},"context":{"title":"Context","description":"The financial sector handles the most sensitive data: trading positions, client information, regulatory filings. DORA mandates digital operational resilience since 2025, including control over ITAD supply chains. Regulators demand flawless traceability."},"regulations":{"title":"Applicable regulations","items":["DORA (Digital Operational Resilience Act)","PCI-DSS v4.0","Financial regulators","Enhanced GDPR","NIS2 (essential entities)","Basel III/IV (operational risk)"]},"challenges":{"title":"Typical challenges","items":["Ultra-sensitive data: trading, clients, compliance","High-security erasure with mandatory 4-eyes validation","Complete audit trail required by regulators","Multi-entity management (subsidiaries, branches)","ITAD providers subject to same DORA requirements","Complex regulatory retention periods"]},"solution":{"title":"How GTC responds","items":["NIST 800-88 Purge/Destroy certified erasure with dual validation","Built-in 4-eyes principle for every critical operation","End-to-end blockchain chain of custody","Pre-configured DORA + PCI-DSS compliance matrix","Auditor reporting with dedicated regulatory exports","DORA Article 28 compliant ITAD provider qualification"]},"cta":{"title":"Secure your financial ITAD","button":"Request a DORA audit"}},"sante":{"hero":{"title":"ITAD for Healthcare","subtitle":"Health data hosting, patient records, privacy — protect health data end-to-end"},"context":{"title":"Context","description":"Healthcare facilities manage particularly sensitive patient data. Health Data Hosting (HDS) certification strictly governs the processing of this data, including its destruction. Data protection authorities are especially vigilant in this sector, with regular audits and enhanced penalties."},"regulations":{"title":"Applicable regulations","items":["HDS certification (Health Data Hosting)","GDPR — health data (art. 9)","Public health code","Data protection authority — health framework","NIS2 (healthcare = essential entity)","National health IT security framework"]},"challenges":{"title":"Typical challenges","items":["Patient data: medical records, imaging, lab results","Mandatory physical destruction for certain media (CDs, tapes, disks)","Regulatory traceability required by authorities","Connected medical devices with embedded data","Multi-site: hospitals, clinics, care homes, practices","Constrained IT budget and aging equipment"]},"solution":{"title":"How GTC responds","items":["Certified erasure and physical destruction for all media types","Certificates compliant with health data hosting requirements","Complete traceability for regulatory audits","Connected medical device (IoMT) management","Multi-facility dashboard for hospital groups","Refurbishable equipment recovery through charitable channels"]},"cta":{"title":"Protect health data","button":"Request a healthcare audit"}},"industrie":{"hero":{"title":"ITAD for Industry","subtitle":"PLCs, SCADA, industrial IoT — manage the lifecycle of your IT/OT equipment"},"context":{"title":"Context","description":"Industry uses a mix of traditional IT and OT (Operational Technology): programmable logic controllers, SCADA systems, IoT sensors. These devices have long lifecycles (10-20 years) and often contain sensitive production data. IT scope 3 emissions are particularly heavy in manufacturing."},"regulations":{"title":"Applicable regulations","items":["NIS2 (industrial sector = important entity)","CSRD / ESRS E5 (circular economy)","WEEE Directive","IEC 62443 (industrial cybersecurity)","ISO 14001 (environmental management)","Machinery Directive 2023/1230"]},"challenges":{"title":"Typical challenges","items":["Heterogeneous fleets: PLCs, SCADA, HMI, industrial PCs","EOSL (End of Service Life) equipment without vendor support","Heavy scope 3 carbon (bulky equipment, rare metals)","Long lifecycles: 10 to 20 years","Specialized equipment difficult to refurbish","Production data and intellectual property embedded in devices"]},"solution":{"title":"How GTC responds","items":["Unified IT/OT inventory with PLC and SCADA management","Erasure adapted to industrial media (flash memory, PLCs)","Precise carbon footprint including heavy equipment via Boavizta","EOSL lifecycle management with alerts and replacement planning","Certified recycling of rare metals and specialized components","Automated CSRD/ESRS E5 reporting for industrial scope 3"]},"cta":{"title":"Optimize your industrial ITAD","button":"Request an industrial audit"}},"public":{"hero":{"title":"ITAD for the Public Sector","subtitle":"Public procurement, WEEE standards, enhanced GDPR — transparency and compliance for government"},"context":{"title":"Context","description":"The public sector (local authorities, government agencies, public institutions) faces enhanced obligations for transparency, GDPR compliance, and public procurement rules. WEEE management standards apply specifically. Procurement specifications are strict and purchasing procedures are governed by public procurement law."},"regulations":{"title":"Applicable regulations","items":["Enhanced GDPR (public accountability)","WEEE management standards","WEEE Directive","Public procurement code","NIS2 (government = essential entities)","Anti-waste and circular economy law"]},"challenges":{"title":"Typical challenges","items":["Public procurement: strict specifications, competitive bidding","Enhanced transparency and traceability obligations","GDPR with increased public servant accountability","Heterogeneous and aging IT fleet","Limited budget, need for maximum value recovery","Mandatory reuse and charitable donations"]},"solution":{"title":"How GTC responds","items":["Platform compliant with public procurement requirements","Transparent and auditable reporting for oversight bodies","GDPR certificates compliant with public sector recommendations","Maximum value recovery through charitable reuse channels","Automated WEEE compliance","Dashboard adapted for government with budget tracking"]},"cta":{"title":"Structure your public sector ITAD","button":"Request a government audit"}},"common":{"context":"Context","regulations":"Regulations","challenges":"Challenges","solution":"Our response","stakeholders":"Stakeholders","scenarioLabel":"Scenario","solutionLabel":"With GreenTechCycle","otherSectors":"Discover other sectors","backToUseCases":"See use cases"}}},"now":"$undefined","timeZone":"UTC","children":[["$","$Lb",null,{}],["$","$Lc",null,{}],["$","main",null,{"className":"pt-[calc(4rem+1.75rem)] lg:pt-[calc(5rem+1.75rem)]","children":["$","$L4",null,{"parallelRouterKey":"children","segmentPath":["children","$5","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L6",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$Ld","notFoundStyles":[]}]}],["$","$Le",null,{}],["$","$Lf",null,{}],["$","$L10",null,{}],["$","$L11",null,{}]]}]
